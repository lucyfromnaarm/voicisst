#!/usr/bin/env bash
set -euo pipefail

unit=voicisst-run-ui.service
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="${VOICISST_PROJECT_ROOT:-$(cd -- "$script_dir/.." && pwd)}"
service_name="${unit%.service}"

if [[ -x "$repo_root/.venv/bin/python" ]]; then
  voicisst_cmd=("$repo_root/.venv/bin/python" -m voicisst)
  pythonpath="$repo_root/src"
elif command -v voicisst >/dev/null 2>&1; then
  voicisst_cmd=("$(command -v voicisst)")
  pythonpath=""
else
  voicisst_cmd=("python3" -m voicisst)
  pythonpath="$repo_root/src"
fi

latest_url() {
  journalctl --user -u "$unit" -n 80 --no-pager 2>/dev/null \
    | grep -Eo 'http://127\.0\.0\.1:[0-9]+/\?t=[A-Za-z0-9_-]+' \
    | tail -n 1
}

if ! systemctl --user is-active --quiet "$unit"; then
  systemctl --user reset-failed "$unit" >/dev/null 2>&1 || true
  run_args=(--user --unit "$service_name" --working-directory="$repo_root")
  if [[ -n "$pythonpath" ]]; then
    run_args+=(--setenv="PYTHONPATH=$pythonpath")
  fi
  systemd-run "${run_args[@]}" "${voicisst_cmd[@]}" run --ui >/dev/null
fi

for _ in {1..30}; do
  url="$(latest_url || true)"
  if [[ -n "${url:-}" ]]; then
    if command -v google-chrome >/dev/null 2>&1; then
      mkdir -p "$HOME/.local/share/voicisst/chrome-profile"
      exec google-chrome \
        --user-data-dir="$HOME/.local/share/voicisst/chrome-profile" \
        --no-first-run \
        --class=Voicisst \
        --name=Voicisst \
        --app="$url"
    fi
    exec xdg-open "$url"
  fi
  sleep 0.2
done

if command -v google-chrome >/dev/null 2>&1; then
  mkdir -p "$HOME/.local/share/voicisst/chrome-profile"
  exec google-chrome \
    --user-data-dir="$HOME/.local/share/voicisst/chrome-profile" \
    --no-first-run \
    --class=Voicisst \
    --name=Voicisst \
    --app=http://127.0.0.1:8766/
fi
exec xdg-open http://127.0.0.1:8766/
